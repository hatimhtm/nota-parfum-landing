---
import Layout from "../layouts/Layout.astro";
import IntroLoader from "../components/IntroLoader.astro";
import SideRail from "../components/SideRail.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Manifesto from "../components/Manifesto.astro";
import Marquee from "../components/Marquee.astro";
import Ritual from "../components/Ritual.astro";
import Collection from "../components/Collection.astro";
import Heritage from "../components/Heritage.astro";
import Reviews from "../components/Reviews.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
---

<Layout>
  <IntroLoader />
  <SideRail />
  <Nav />
  <main>
    <Hero />
    <Manifesto />
    <Marquee />
    <Ritual />
    <Collection />
    <Heritage />
    <Reviews />
    <Footer />
  </main>
  <FloatingWhatsApp />
</Layout>
