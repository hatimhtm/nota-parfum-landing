---
import { whatsapp, withBase } from "../data/brand";
import WhatsAppIcon from "./WhatsAppIcon.astro";

const links = [
  { href: "#decouvrir", label: "Découvrir" },
  { href: "#collection", label: "Collection" },
  { href: "#atelier", label: "L'Atelier de Fès" },
  { href: "#avis", label: "Avis" },
  { href: "#contact", label: "Contact" },
];
const whatsappHref = whatsapp.collection;
---

<nav data-nav class="sticky top-0 z-50">
  <div class="container-page flex items-center justify-between py-4">
    <a href="#top" class="flex items-center" aria-label="Nota Parfum, retour en haut">
      <img
        src={withBase("brand/logo.png")}
        alt="Nota Parfum"
        class="logo-img h-12 w-auto md:h-14"
        width="320"
        height="320"
      />
    </a>

    <div class="hidden md:flex items-center gap-7">
      {links.map((l) => (
        <a href={l.href} class="nav-link">{l.label}</a>
      ))}
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener"
        class="btn btn-ghost text-[10px] !py-2 !px-3.5"
        aria-label="Contacter Nota Parfum sur WhatsApp"
      >
        <WhatsAppIcon size={12} />
        WhatsApp
      </a>
    </div>

    <a
      href={whatsappHref}
      target="_blank"
      rel="noopener"
      class="md:hidden btn btn-ghost text-[10px] !py-2 !px-3"
      aria-label="Contacter Nota Parfum sur WhatsApp"
    >
      <WhatsAppIcon size={12} />
      WhatsApp
    </a>
  </div>
</nav>
