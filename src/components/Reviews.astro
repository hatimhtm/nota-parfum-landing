---
import { reviews } from "../data/reviews";

const langLabel: Record<string, string> = {
  fr: "Français",
  darija: "Darija marocaine",
  "darija-fr": "Darija · Français",
};
---

<section id="avis" class="relative bg-cream-deep py-24 lg:py-32 overflow-hidden">
  <span class="chapter-num" style="top: 4%; right: 4%;" aria-hidden="true">VI</span>
  <div class="container-page relative">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3" data-reveal>
        <span class="h-px w-10 bg-gold"></span>
        <p class="eyebrow">Les avis</p>
      </div>
      <h2 class="display-lg mt-5" data-reveal data-reveal-delay="0.1">
        Ce que disent <span class="italic font-light">nos client·e·s</span>.
      </h2>
      <p class="mt-6 text-ink-soft leading-relaxed text-lg" data-reveal data-reveal-delay="0.2">
        Des messages reçus sur Instagram, en français et en darija — la langue dans laquelle
        nous parlons à notre clientèle marocaine. Nous les laissons tels quels, parce que c'est
        ainsi qu'ils ont été dits.
      </p>
    </div>

    <div class="hair mt-14 mb-14" data-reveal></div>

    <div class="grid md:grid-cols-2 gap-10 lg:gap-14" data-stagger>
      {reviews.map((r) => (
        <figure data-stagger-item class="relative bg-cream px-8 py-10 lg:px-10 lg:py-12 border border-ink/5">
          <span aria-hidden="true" class="absolute -top-4 left-8 font-display text-6xl leading-none text-gold select-none">«</span>
          <blockquote class="font-display text-xl lg:text-2xl leading-snug text-ink">
            {r.quote}
          </blockquote>
          {r.translation && (
            <p class="mt-5 text-sm italic text-ink-mute leading-relaxed">— {r.translation}</p>
          )}
          <figcaption class="mt-7 flex items-center justify-between gap-4 text-[11px] font-mono uppercase tracking-[0.18em]">
            <span class="text-ink-soft">{r.author}</span>
            <span class="text-ink-mute">{langLabel[r.language]}</span>
          </figcaption>
          {r.fragrance && (
            <p class="mt-3 text-[11px] font-mono uppercase tracking-[0.18em] text-gold">
              ↳ <span class="italic normal-case tracking-normal text-coral text-sm font-display">{r.fragrance}</span>
            </p>
          )}
        </figure>
      ))}
    </div>
  </div>
</section>
