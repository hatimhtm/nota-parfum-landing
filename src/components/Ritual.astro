---
import { whatsapp } from "../data/brand";

const whatsappHref = whatsapp.trio;

const steps = [
  {
    n: "01",
    title: "Composez",
    body: "Choisissez trois fragrances dans la collection — féminines, masculines, ou un mélange des deux.",
  },
  {
    n: "02",
    title: "Confirmez sur WhatsApp",
    body: "Envoyez-nous votre sélection et votre adresse. Nous confirmons en moins d'une heure, dans la journée.",
  },
  {
    n: "03",
    title: "Recevez en 48 heures",
    body: "Paiement à la livraison. Livraison partout au Maroc — Casablanca, Rabat, Marrakech, Tanger, et toutes les régions.",
  },
];
---

<section id="decouvrir" class="relative bg-emerald text-cream py-24 lg:py-32 overflow-hidden">
  <div class="grain" aria-hidden="true"></div>
  <span class="chapter-num" style="top: 6%; right: 4%; color: var(--color-gold-soft); opacity: 0.14;" aria-hidden="true">III</span>

  <div class="container-page relative">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-5 order-2 lg:order-1 reveal">
        <figure class="relative aspect-[4/5] overflow-hidden border border-emerald-mist">
          <img
            src="/brand/bottle-trio-orchard.jpg"
            alt="Trois flacons Nota Parfum dans un verger, parmi des pétales de rose"
            class="h-full w-full object-cover"
            width="900"
            height="1125"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2">
        <div class="flex items-center gap-3 reveal">
          <span class="h-px w-10 bg-gold-soft opacity-60"></span>
          <p class="eyebrow-light">Le pack signature</p>
        </div>
        <h2 class="display-xl mt-5 text-cream reveal reveal-delay-1">
          Trois fragrances.
          <br />
          <span class="italic font-light text-gold-soft">Cent trente-neuf</span> dirhams.
        </h2>
        <p class="mt-7 max-w-xl text-base lg:text-[17px] leading-relaxed text-cream/80 reveal reveal-delay-2">
          Une formule pour découvrir, pour offrir, ou tout simplement pour soi.
          Trois flacons choisis dans toute la collection, livrés en quarante-huit heures, payés à la réception.
        </p>

        <a href={whatsappHref} target="_blank" rel="noopener" class="btn btn-light mt-10 reveal reveal-delay-3" data-magnetic>
          Composer mon pack
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <div class="hair mt-20 mb-14 opacity-30 reveal"></div>

    <ol class="grid md:grid-cols-3 gap-10 lg:gap-16">
      {steps.map((s, i) => (
        <li class={`reveal reveal-delay-${i + 1}`}>
          <p class="font-mono text-[11px] tracking-[0.22em] text-gold-soft uppercase">Étape {s.n}</p>
          <h3 class="display-md mt-4 text-cream">{s.title}</h3>
          <p class="mt-4 text-cream/75 leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
