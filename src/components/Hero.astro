---
import { whatsapp, withBase } from "../data/brand";
import WhatsAppIcon from "./WhatsAppIcon.astro";

const whatsappHref = whatsapp.order;
---

<section id="top" class="relative overflow-hidden bg-cream">
  <span class="chapter-num" style="top: 8%; right: 4%;" aria-hidden="true">I</span>

  <div class="container-page grid lg:grid-cols-12 gap-10 lg:gap-16 items-center pt-14 pb-24 lg:pt-28 lg:pb-36 relative">
    <div class="lg:col-span-7 relative z-10">
      <div class="flex items-center gap-3" data-reveal>
        <span class="h-px w-10 bg-gold"></span>
        <p class="eyebrow !text-ink">Parfumerie · Fès, Maroc</p>
      </div>

      <h1 class="display-xl mt-7">
        <span class="block" data-split-words>L'essence de votre</span>
        <span class="block italic font-light text-coral" data-split-words>signature.</span>
      </h1>

      <p class="mt-8 max-w-xl text-base lg:text-[17px] leading-relaxed text-ink-soft" data-reveal data-reveal-delay="0.9">
        Vingt-quatre fragrances inspirées des plus grandes maisons.
        Embouteillées à la main à Fès, livrées en quarante-huit heures partout au Maroc.
        Le geste de la parfumerie, à un prix qui n'en demande aucun.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4" data-reveal data-reveal-delay="1.0">
        <a href="#collection" class="btn btn-primary" data-magnetic>
          Découvrir la collection
          <span aria-hidden="true">→</span>
        </a>
        <a href={whatsappHref} target="_blank" rel="noopener" class="btn btn-ghost" data-magnetic>
          <WhatsAppIcon size={13} />
          Commander
        </a>
      </div>

      <div class="mt-16 grid grid-cols-3 max-w-md text-left" data-stagger>
        <div class="border-r border-gold/40 pr-4" data-stagger-item>
          <p class="font-display text-3xl lg:text-4xl">24</p>
          <p class="eyebrow mt-1">Fragrances</p>
        </div>
        <div class="border-r border-gold/40 px-4" data-stagger-item>
          <p class="font-display text-3xl lg:text-4xl">139<span class="text-base align-top ml-0.5">dh</span></p>
          <p class="eyebrow mt-1">Pack de trois</p>
        </div>
        <div class="pl-4" data-stagger-item>
          <p class="font-display text-3xl lg:text-4xl">48<span class="text-base align-top ml-0.5">h</span></p>
          <p class="eyebrow mt-1">Livraison Maroc</p>
        </div>
      </div>
    </div>

    <div class="lg:col-span-5 relative z-10">
      <figure class="relative aspect-[4/5] w-full overflow-hidden bg-emerald" data-clip-reveal>
        <img
          src={withBase("brand/bottle-burberry-pair.jpg")}
          alt="Deux flacons Nota Parfum Burberry Her, 50ml et 30ml, sur fond émeraude"
          class="h-full w-full object-cover"
          style="object-position: center 35%;"
          width="900"
          height="1125"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-emerald/40 via-transparent to-transparent" aria-hidden="true"></div>
        <div class="grain"></div>
        <figcaption class="absolute bottom-5 left-5 right-5 flex items-end justify-between text-cream">
          <div>
            <p class="eyebrow-light">N°06 · Burberry</p>
            <p class="font-display italic text-2xl mt-1 text-cream">Her</p>
          </div>
          <p class="font-mono text-[10px] tracking-[0.18em] uppercase opacity-70">
            50&nbsp;ml &middot; 1.7&nbsp;fl&nbsp;oz
          </p>
        </figcaption>
      </figure>
    </div>
  </div>

  <a href="#manifeste" class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2 text-ink-soft hover:text-ink transition-colors group" aria-label="Faire défiler vers le manifeste">
    <span class="font-mono text-[10px] tracking-[0.28em] uppercase">Faire défiler</span>
    <span class="w-px h-10 bg-current opacity-40 group-hover:h-14 transition-all duration-500"></span>
  </a>
</section>
