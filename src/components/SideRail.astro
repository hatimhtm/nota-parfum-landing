---
const sections = [
  { id: "top", label: "Hero" },
  { id: "manifeste", label: "Manifeste" },
  { id: "decouvrir", label: "Le Rituel" },
  { id: "collection", label: "Collection" },
  { id: "atelier", label: "L'Atelier" },
  { id: "avis", label: "Avis" },
  { id: "contact", label: "Contact" },
];
---

<nav class="side-rail" aria-label="Sections de la page">
  {sections.map((s) => (
    <a
      href={`#${s.id}`}
      class="side-rail__dot"
      data-rail-target={s.id}
      data-label={s.label}
      aria-label={`Aller à la section ${s.label}`}
    ></a>
  ))}
</nav>
