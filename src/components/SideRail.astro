---
const sections = [
  { id: "top", label: "Hero" },
  { id: "manifeste", label: "Manifeste" },
  { id: "decouvrir", label: "Le Rituel" },
  { id: "collection", label: "Collection" },
  { id: "atelier", label: "L'Atelier" },
  { id: "avis", label: "Avis" },
  { id: "contact", label: "Contact" },
];
---

<nav class="side-rail" aria-label="Sections de la page">
  {sections.map((s) => (
    <a
      href={`#${s.id}`}
      class="side-rail__dot"
      data-rail-target={s.id}
      data-label={s.label}
      aria-label={`Aller à la section ${s.label}`}
    ></a>
  ))}
</nav>

<script is:inline>
  // Highlight the rail dot for the section currently in view.
  (() => {
    const dots = document.querySelectorAll(".side-rail__dot");
    if (!dots.length) return;
    const sections = Array.from(dots)
      .map((d) => {
        const id = d.getAttribute("data-rail-target");
        const el = id ? document.getElementById(id) : null;
        return { dot: d, el };
      })
      .filter((s) => s.el);

    const setActive = (id) => {
      dots.forEach((d) => {
        if (d.getAttribute("data-rail-target") === id) {
          d.classList.add("is-active");
        } else {
          d.classList.remove("is-active");
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const intersecting = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (intersecting) {
          setActive(intersecting.target.id);
        }
      },
      { threshold: [0.25, 0.5, 0.75], rootMargin: "-20% 0px -40% 0px" }
    );

    sections.forEach((s) => s.el && observer.observe(s.el));
  })();
</script>
